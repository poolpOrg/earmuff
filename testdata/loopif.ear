// docs/language-v2.md §4c — loop index + if/else over the bound loop index.
project "loop if" {
    bpm 120; time 4 4;

    track "rythm guitar" instrument "guitar" {
        for i in 1..2 {
            if i == 2 {
                bar whole { C^7/G }      // last pass: voice the fifth in the bass
            } else {
                bar whole { C^7/E }
            }
        }
    }
}
