{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "earmuff",
  "scopeName": "source.earmuff",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#chords" },
    { "include": "#notes" },
    { "include": "#durations" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.earmuff",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.earmuff",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.earmuff",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.earmuff",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.earmuff",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.earmuff",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.earmuff",
          "match": "\\b(for|each|in|if|else|repeat)\\b"
        },
        {
          "name": "keyword.other.earmuff",
          "match": "\\b(project|track|bar|pattern|section|kit|instrument|channel|port|bpm|time|copyright|text|lyric|marker|cue|on|beat|let|swing|cc|bend|raw|range|pressure|program|sysex|then|over)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.earmuff",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.dynamic.earmuff",
          "match": "\\b(ppp|pp|p|mp|mf|f|ff|fff)\\b"
        }
      ]
    },
    "chords": {
      "patterns": [
        {
          "comment": "A chord: a root with a quality or bare-digit quality (Cmaj7, Am7, C5, G7), optional slash bass. No caret.",
          "name": "entity.name.type.chord.earmuff",
          "match": "\\b[A-G](#|b)*(maj|min|dim|aug|sus|add|m|M|\\d)\\w*(/[A-G](#|b)*\\d*)?\\b"
        }
      ]
    },
    "notes": {
      "patterns": [
        {
          "comment": "A note: a pitch with a caret octave marker (C^, C^5, Eb^3) — never a chord.",
          "name": "constant.other.note.earmuff",
          "match": "\\b[A-G](#|b)*\\^\\d*"
        },
        {
          "comment": "A bare note (letter + accidentals, no caret, no quality) at the default octave.",
          "name": "constant.other.note.earmuff",
          "match": "\\b[A-G](#|b)*(?![A-Za-z0-9^])"
        }
      ]
    },
    "durations": {
      "patterns": [
        {
          "name": "support.type.duration.earmuff",
          "match": "\\b(whole|half|quarter|eighth|sixteenth|thirtysecond|sixtyfourth)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.earmuff",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.earmuff",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.earmuff",
          "match": "(==|!=|<=|>=|&&|\\|\\||\\.\\.|<|>|=|\\+|-|\\*|/|!|:|\\||@|~)"
        }
      ]
    }
  }
}
